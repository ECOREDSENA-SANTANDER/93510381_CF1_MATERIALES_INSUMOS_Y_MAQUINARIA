ACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Actividad.vue","sourceRoot":"src/views","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Fibras e hilos',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b> Objetivo:</b> evaluar la comprensión de los conceptos fundamentales sobre fibras e hilos, incluyendo sus tipos, propiedades, procesos de producción y aplicaciones en la industria textil.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            'La longitud influye en la suavidad y caída de la tela y se mide en micras o milésimas de milímetro, y su valor promedio determina el grosor de las fibras.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto:\n            'La viscosa rayón es un compuesto de celulosa extraída de la pulpa de algunos árboles como los abetos. ',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto:\n            'Las fibras regeneradas son aquellas obtenidas a partir de materia prima natural, como la celulosa, que es procesada químicamente para formar nuevas fibras.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            'Los materiales antimicrobianos ofrecen una barrera especial contra los ácaros, siendo ideales para personas alérgicas.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto:\n            'La torsión izquierda (Z): se enrolla en sentido a las manecillas del reloj.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 6,\n          texto:\n            'Los hilos sintéticos son elaborados a través de procesos químicos, especialmente de derivados del petróleo, el carbón y otros minerales.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 7,\n          texto:\n            'El hilo multifilamento es suave y se elabora comúnmente de nailon o poliéster.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 8,\n          texto:\n            'Es una recomendación para la confección de ropa interior: definir la calidad del hilo que necesita utilizar.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 9,\n          texto:\n            'El decitex (dtex) se basa en una longitud constante de 9000 m y un peso estándar.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 10,\n          texto:\n            'El hilo se puede clasificar de diferentes maneras, algunas clasificaciones comunes se basan en: substrato, construcción y terminado.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}