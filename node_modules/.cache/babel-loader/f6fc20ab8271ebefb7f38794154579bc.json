os esenciales en la industria textil, y su correcta selección depende del origen, las propiedades y el uso que se les dará en la confección de distintos productos.\")]),_c('div',{staticClass:\"row justify-content-center\"},[_vm._m(0),_c('div',{staticClass:\"col-auto\"},[_c('a',{staticClass:\"anexo mb-5\",attrs:{\"href\":_vm.obtenerLink('/downloads/sintesis.pdf'),\"target\":\"_blank\"}},[_vm._m(1),_vm._m(2)])])])])],1)\n}\nvar staticRenderFns = [function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"col-lg-12 mb-5 bgs p-4 brad\"},[_c('figure',[_c('img',{attrs:{\"src\":require(\"@/assets/curso/sintesis.svg\"),\"alt\":\"Las fibras e hilos se clasifican según su composición y propiedades. Las fibras pueden ser de origen animal, vegetal, mineral, sintéticas o artificiales. Los hilos, por su parte, se diferencian según su composición, lo que influye en su uso y resistencia en la confección textil.\"}})])])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"anexo__icono\"},[_c('img',{attrs:{\"src\":require(\"@/assets/bullets/icono-pdf.svg\")}})])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"anexo__texto\"},[_c('p',[_vm._v(\"Anexo. Síntesis\")])])\n}]\n\nexport { render, staticRenderFns }"],"mappings":"AAAA,IAAIA,MAAM,GAAG,SAASA,MAAMA,CAAA,EAAE;EAAC,IAAIC,GAAG,GAAC,IAAI;IAACC,EAAE,GAACD,GAAG,CAACE,KAAK,CAACD,EAAE;EAAC,OAAOA,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA2B,CAAC,EAAC,CAACF,EAAE,CAAC,eAAe,EAAC;IAACG,KAAK,EAAC;MAAC,OAAO,EAAC,gBAAgB;MAAC,QAAQ,EAAC;IAAU;EAAC,CAAC,CAAC,EAACH,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA8C,CAAC,EAAC,CAACF,EAAE,CAAC,GAAG,EAAC,CAACD,GAAG,CAACK,EAAE,CAAC,s6BAAs6B,CAAC,CAAC,CAAC,EAACJ,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA4B,CAAC,EAAC,CAACH,GAAG,CAACM,EAAE,CAAC,CAAC,CAAC,EAACL,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAU,CAAC,EAAC,CAACF,EAAE,CAAC,GAAG,EAAC;IAACE,WAAW,EAAC,YAAY;IAACC,KAAK,EAAC;MAAC,MAAM,EAACJ,GAAG,CAACO,WAAW,CAAC,yBAAyB,CAAC;MAAC,QAAQ,EAAC;IAAQ;EAAC,CAAC,EAAC,CAACP,